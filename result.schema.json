{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://discoverphysics.github.io/schema/result.schema.json",
  "title": "DiscoverPhysics submission entry",
  "description": "Schema for a single model's results on the DiscoverPhysics benchmark. Submissions add one object of this shape to data/results.json under the `results` array.",
  "type": "object",
  "required": [
    "model",
    "model_display",
    "organization",
    "type",
    "explanation_score",
    "normalized_mse",
    "pass_at_k",
    "per_world_explanation",
    "submission"
  ],
  "properties": {
    "model": {
      "type": "string",
      "description": "Canonical model identifier, lowercase with hyphens",
      "pattern": "^[a-z0-9._-]+$"
    },
    "model_display": {
      "type": "string",
      "description": "Human-readable model name shown in the leaderboard"
    },
    "organization": {
      "type": "string",
      "description": "Organization that produced the model"
    },
    "type": {
      "type": "string",
      "enum": ["proprietary", "open-source"]
    },
    "release_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "Model release date in YYYY-MM format"
    },
    "explanation_score": {
      "type": "object",
      "required": ["mean"],
      "properties": {
        "mean": { "type": "number", "minimum": 0, "maximum": 1 },
        "se": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "normalized_mse": {
      "type": "object",
      "required": ["mean"],
      "properties": {
        "mean": { "type": "number", "minimum": 0 }
      }
    },
    "pass_at_k": {
      "type": "object",
      "required": ["1", "2", "3", "4", "5"],
      "patternProperties": {
        "^[1-9][0-9]*$": {
          "type": "object",
          "required": ["mean"],
          "properties": {
            "mean": { "type": "number", "minimum": 0, "maximum": 100 },
            "se": { "type": ["number", "null"], "minimum": 0 }
          }
        }
      }
    },
    "per_world_explanation": {
      "type": "object",
      "description": "Mean explanation score (0-1) per world. Keys must match the world ids in data/worlds.json.",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "submission": {
      "type": "object",
      "required": ["submitted_by", "submission_date", "rounds_budget", "experimentation_mode"],
      "properties": {
        "submitted_by": { "type": "string" },
        "submission_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "rounds_budget": { "type": "integer", "minimum": 1 },
        "experimentation_mode": {
          "type": "string",
          "enum": ["guided", "random"]
        },
        "notes": { "type": ["string", "null"] },
        "results_dump_url": {
          "type": "string",
          "format": "uri",
          "description": "Optional link to raw per-seed results for verification"
        }
      }
    }
  }
}
